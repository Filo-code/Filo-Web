# -------------------------------------------------------------
# Filo - Environment Variables Template
# -------------------------------------------------------------
# Copy this file to .env.local for local development.
# Configure the same required variables in production (for example Vercel).
# Do not commit real secrets.

# -------------------------------------------------------------
# Website -> n8n lead webhook
# -------------------------------------------------------------
# Server-side only. Used by src/app/api/contact/route.ts.
GOOGLE_SHEETS_WEBHOOK_URL="https://n8n.filo-ai.it/webhook/filo-lead"

# Shared secret sent by /api/contact as x-filo-webhook-secret.
# Must match the lead intake webhook secret expected by n8n.
LEADINTAKE_WEBHOOK_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"

# -------------------------------------------------------------
# Google Sheets / n8n workflow
# -------------------------------------------------------------
# Consumed by the n8n workflow, not by the public frontend.
GOOGLE_SHEET_ID="CHANGE_ME"
GOOGLE_SHEET_TAB="Leads"

# -------------------------------------------------------------
# Telegram owner notification
# -------------------------------------------------------------
# Consumed by the n8n workflow for owner notifications.
TELEGRAM_BOT_TOKEN="CHANGE_ME"
TELEGRAM_CHAT_ID="CHANGE_ME"

# -------------------------------------------------------------
# Resend customer email
# -------------------------------------------------------------
# Consumed by the n8n workflow if customer confirmation email is enabled.
RESEND_API_KEY="CHANGE_ME"
RESEND_FROM_EMAIL="Filò <info@send.filo-ai.it>"

# -------------------------------------------------------------
# Optional email fallback / legacy SMTP
# -------------------------------------------------------------
# Keep empty unless the n8n workflow uses SMTP fallback nodes.
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="info@filo-ai.it"

# -------------------------------------------------------------
# Analytics / future tracking
# -------------------------------------------------------------
# Public IDs only. Tags must remain consent-gated before activation.
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
